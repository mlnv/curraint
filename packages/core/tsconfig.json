{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "declarationDir": "dist",
    "composite": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": ["src/*.ts", "src/**/*.ts"]
}
