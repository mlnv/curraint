{
  "name": "@curraint/cli",
  "version": "0.1.0",
  "description": "CLI application for curraint",
  "main": "dist/index.js",
  "bin": {
    "curraint": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --platform node --format cjs --out-dir dist",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@curraint/core": "workspace:*",
    "@github/copilot-sdk": "^0.1.30"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
