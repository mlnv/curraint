{
  "name": "@curraint/cli",
  "version": "0.1.0",
  "description": "CLI application for curraint",
  "author": "Maksym Yemelianov",
  "main": "dist/index.js",
  "bin": {
    "curraint": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "package": "tsup --config tsup.package.config.ts",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@curraint/core": "workspace:*",
    "@github/copilot-sdk": "^0.1.30",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
