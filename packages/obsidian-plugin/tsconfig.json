{
  "compilerOptions": {
    "target": "ES2018",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2018", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "composite": true,
    "types": ["node"]
  },
  "include": ["src/*.ts", "src/**/*.ts"],
  "references": [
    { "path": "../core" }
  ]
}
