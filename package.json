{
  "name": "curraint",
  "version": "0.1.0",
  "description": "Tray-first AI chat app for desktop and CLI using OpenAI-compatible chat completion endpoints.",
  "author": "Maksym Yemelianov",
  "license": "AGPL-3.0-only",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/generate-licenses.mjs",
