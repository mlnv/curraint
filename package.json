    "generate:licenses": "node scripts/generate-licenses.mjs",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "desktop": "pnpm --filter @curraint/desktop start",
    "cli": "pnpm --filter @curraint/cli start",
    "test:e2e": "pnpm --filter @curraint/desktop-e2e e2e"
